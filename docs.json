{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "UseZombie",
  "colors": {
    "primary": "#d96b2b",
    "light": "#e78a3c",
    "dark": "#c45a1f"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "how-it-works",
              "concepts"
            ]
          },
          {
            "group": "Specs",
            "pages": [
              "specs/writing-specs",
              "specs/supported-formats",
              "specs/validation"
            ]
          },
          {
            "group": "Runs",
            "pages": [
              "runs/submitting",
              "runs/gate-loop",
              "runs/scorecard",
              "runs/pr-output",
              "runs/troubleshooting"
            ]
          },
          {
            "group": "Workspaces",
            "pages": [
              "workspaces/overview",
              "workspaces/managing"
            ]
          },
          {
            "group": "Billing and cost control",
            "pages": [
              "billing/plans",
              "billing/budgets"
            ]
          },
          {
            "group": "CLI reference",
            "pages": [
              "cli/install",
              "cli/zombiectl",
              "cli/flags",
              "cli/configuration"
            ]
          },
          {
            "group": "Updates",
            "pages": [
              "changelog"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "openapi": "https://raw.githubusercontent.com/usezombie/usezombie/main/public/openapi.json",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction",
              "api-reference/error-codes"
            ]
          },
          {
            "group": "Health",
            "pages": [
              "GET /healthz",
              "GET /readyz",
              "GET /metrics"
            ]
          },
          {
            "group": "Authentication",
            "pages": [
              "POST /v1/auth/sessions",
              "GET /v1/auth/sessions/{session_id}",
              "POST /v1/auth/sessions/{session_id}/complete",
              "GET /v1/github/callback"
            ]
          },
          {
            "group": "Workspaces",
            "pages": [
              "POST /v1/workspaces",
              "POST /v1/workspaces/{workspace_id}:pause",
              "POST /v1/workspaces/{workspace_id}:sync"
            ]
          },
          {
            "group": "Runs",
            "pages": [
              "POST /v1/runs",
              "GET /v1/runs",
              "GET /v1/runs/{run_id}",
              "POST /v1/runs/{run_id}:retry",
              "GET /v1/runs/{run_id}:replay",
              "GET /v1/runs/{run_id}:stream",
              "POST /v1/runs/{run_id}:cancel"
            ]
          },
          {
            "group": "Credentials",
            "pages": [
              "PUT /v1/workspaces/{workspace_id}/credentials/llm",
              "GET /v1/workspaces/{workspace_id}/credentials/llm",
              "DELETE /v1/workspaces/{workspace_id}/credentials/llm"
            ]
          },
          {
            "group": "Skill Secrets",
            "pages": [
              "PUT /v1/workspaces/{workspace_id}/skills/{skill_ref}/secrets/{key_name}",
              "DELETE /v1/workspaces/{workspace_id}/skills/{skill_ref}/secrets/{key_name}"
            ]
          },
          {
            "group": "Admin",
            "pages": [
              "GET /v1/admin/platform-keys",
              "PUT /v1/admin/platform-keys",
              "DELETE /v1/admin/platform-keys/{provider}"
            ]
          },
          {
            "group": "Billing",
            "pages": [
              "POST /v1/workspaces/{workspace_id}/billing/scale",
              "POST /v1/workspaces/{workspace_id}/billing/events"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Website",
          "href": "https://usezombie.com",
          "icon": "globe"
        },
        {
          "anchor": "GitHub",
          "href": "https://github.com/usezombie/usezombie",
          "icon": "github"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Changelog",
        "href": "/changelog"
      },
      {
